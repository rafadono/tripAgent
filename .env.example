GOOGLE_MAPS_API_KEY=replace_me

# Guardrails
TRIPAGENT_COSTLY_ENDPOINTS_ENABLED=true
TRIPAGENT_PLAN_ENDPOINT_ENABLED=true
TRIPAGENT_FALLBACK_MODE_ENABLED=false
TRIPAGENT_FALLBACK_MESSAGE=Optimizacion temporalmente no disponible por control de costos.
TRIPAGENT_ADMIN_TOKEN=change-this-admin-token
TRIPAGENT_AUTH_ENABLED=true
TRIPAGENT_AUTH_USERS=demo:demo123
TRIPAGENT_SESSION_TTL_SEC=86400
TRIPAGENT_PLAN_DAILY_QUOTA_PER_USER=20
TRIPAGENT_FREE_DAILY_QUOTA_PER_USER=10
TRIPAGENT_PRO_DAILY_QUOTA_PER_USER=100
TRIPAGENT_PLAN_QUEUE_ENABLED=true
TRIPAGENT_EST_ADS_REVENUE_PER_REQUEST=0.0
TRIPAGENT_SUBSCRIPTION_MONTHLY_PRICE=0.0
TRIPAGENT_MONETIZATION_TARGET_MARGIN=0.15
TRIPAGENT_INFRA_MONTHLY_COST_ESTIMATE=0.0
TRIPAGENT_SUBSCRIPTION_PRICE_MIN=0.0
TRIPAGENT_SUBSCRIPTION_PRICE_MAX=1000000
TRIPAGENT_MAX_PRICE_CHANGE_PCT=0.2
TRIPAGENT_TARGET_CONVERSION_RATE=0.03
TRIPAGENT_DB_PATH=out/tripagent.db

# API access control
TRIPAGENT_REQUIRE_API_KEY=false
TRIPAGENT_API_KEYS=demo-key-1,demo-key-2

# Rate limits (per window)
TRIPAGENT_RATE_LIMIT_WINDOW_SEC=60
TRIPAGENT_RATE_LIMIT_PLAN_PER_WINDOW=8
TRIPAGENT_RATE_LIMIT_SEARCH_PER_WINDOW=20
TRIPAGENT_RATE_LIMIT_PARKING_PER_WINDOW=20
TRIPAGENT_CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Cache
TRIPAGENT_CACHE_ENABLED=true
TRIPAGENT_CACHE_BACKEND=memory
TRIPAGENT_CACHE_REDIS_URL=redis://redis:6379/0
TRIPAGENT_CACHE_TTL_PLACE_DETAILS_SEC=3600
TRIPAGENT_CACHE_TTL_TEXT_SEARCH_SEC=1800
TRIPAGENT_CACHE_TTL_NEARBY_SEARCH_SEC=300
TRIPAGENT_CACHE_TTL_ROUTE_MATRIX_SEC=300
TRIPAGENT_CACHE_TTL_POLYLINE_SEC=300

# Estimated API unit costs (set from your current Google pricing sheet)
TRIPAGENT_COST_PLACES_TEXT_SEARCH=0.0
TRIPAGENT_COST_PLACES_NEARBY=0.0
TRIPAGENT_COST_PLACES_DETAILS=0.0
TRIPAGENT_COST_ROUTES_MATRIX=0.0
TRIPAGENT_COST_ROUTES_POLYLINE=0.0

# Health checks
TRIPAGENT_HEALTH_CHECK_UPSTREAM_ENABLED=false

# Budget controls
TRIPAGENT_DAILY_BUDGET_LIMIT=0
TRIPAGENT_BUDGET_ALERT_THRESHOLD_WARN=0.7
TRIPAGENT_BUDGET_ALERT_THRESHOLD_CRITICAL=0.9
TRIPAGENT_BUDGET_AUTO_FALLBACK=false

# Experimentation
TRIPAGENT_AB_TEST_ENABLED=true
